{
  "kind": "collectionType",
  "collectionName": "page_templates",
  "info": {
    "singularName": "page-template",
    "pluralName": "page-templates",
    "displayName": "Page Template"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "layout": {
      "type": "dynamiczone",
      "components": [
        "page-blocks.text-block",
        "page-blocks.image-gallery",
        "page-blocks.hero",
        "page-blocks.feature-grid",
        "page-blocks.button"
      ],
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "page",
        "blog",
        "news",
        "service"
      ],
      "required": true
    },
    "isDefault": {
      "type": "boolean",
      "default": false
    }
  }
}
